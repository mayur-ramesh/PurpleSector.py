# PurpleSector.py — environment variable reference
# Copy this file to .env and fill in any values you want to override.
# All variables are optional; the defaults shown here are what the app uses if the variable is unset.

# ── Backend ────────────────────────────────────────────────────────────────────

# Host and port for the FastAPI server.
# The Vite dev-server proxy expects the backend on port 8008.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8008

# ── CORS ───────────────────────────────────────────────────────────────────────

# Comma-separated list of frontend origins allowed to call the API.
# In production set this to your deployed frontend URL(s).
# Defaults to * (all origins) when unset — fine for local development.
# Note: credentials (cookies) are disabled when the wildcard is used.
ALLOWED_ORIGINS=https://your-frontend.up.railway.app

# ── FastF1 cache ───────────────────────────────────────────────────────────────

# Directory where FastF1 stores downloaded session data.
# Defaults to ~/.fastf1_cache if left unset.
# On Railway, point this at a mounted volume path for persistence across deploys.
FASTF1_CACHE_DIR=~/.fastf1_cache
