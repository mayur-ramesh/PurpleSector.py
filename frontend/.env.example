# Base URL for the FastAPI backend.
# In development this can point directly at the local backend, or be left empty
# to fall back to the Vite dev-server proxy (which forwards /api/* to localhost:8008).
# In production (Vercel) set this to the deployed Railway backend URL.
VITE_API_BASE_URL=http://localhost:8000

# Public URL of the deployed frontend — used for Open Graph og:image and og:url meta tags.
# In production (Vercel) set this to your actual deployment URL (no trailing slash).
# During local dev this can be omitted; OG tags won't resolve but the app works normally.
VITE_APP_URL=https://your-purplesector-app.vercel.app
